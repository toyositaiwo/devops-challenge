{
  "name": "devops-challenge-app",
  "version": "1.0.0",
  "description": "Production-ready DevOps challenge app deployed on AWS ECS Fargate",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "test": "jest --testEnvironment=node --forceExit --coverage",
    "test:ci": "jest --testEnvironment=node --forceExit --ci --coverage"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testMatch": ["**/*.test.js"],
    "collectCoverageFrom": ["index.js"]
  }
}